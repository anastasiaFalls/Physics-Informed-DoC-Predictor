def example_build_isoconversion_csv(output_path="outputs/isoconversion_parameters.csv"):
    """
    Example showing how your DSC preprocessing code connects to the LSTM prototype.

    Uncomment and edit paths when your DSC CSVs are in the working directory.
    This produces the file expected by load_isoconversion_parameters().
    """
    os.makedirs(os.path.dirname(output_path), exist_ok=True)

    dsc_settings = [
        # path, resin weight, baseline slice indices
        ("Resinat0.5.csv", 7.1e-3, (1, 2275, 10604, None)),
        ("Resinat4.csv", 7.6e-3, (1, 2590, 18616, None)),
        ("Resinat8.csv", 9.5e-3, (1, 1912, 9305, None)),
        ("Resinat10.csv", 6.5e-3, (1, 1786, 7356, None)),
    ]

    processed = []
    for path, weight, slices in dsc_settings:
        if not os.path.exists(path):
            print(f"Skipping missing DSC file: {path}")
            continue
        processed.append(load_and_process_dsc_csv(path, weight, slices))

    if len(processed) < 2:
        raise RuntimeError("Need at least two DSC runs to fit isoconversion parameters.")

    params = fit_isoconversion_parameters(processed)
    params.to_csv(output_path, index=False)
    print(f"Saved isoconversion parameters to {output_path}")
    return params


