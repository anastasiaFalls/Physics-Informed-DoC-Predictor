def main():
    output_dir = "outputs"
    os.makedirs(output_dir, exist_ok=True)

    # ------------------------------------------------------------
    # Step 1: Load dataset from CSV folders
    # ------------------------------------------------------------
    # Your folders should contain CSV files with columns:
    # Time, Temperature, Sensor_Value, Degree_of_Cure, Cure_Index
    #
    # Update these paths to match your computer.
    folder_1 = "/Users/anastasia/Desktop/artificial_sensor_dataset_with_inlet 2"
    folder_2 = "/Users/anastasia/Desktop/artificial_sensor_dataset 2"

    use_csv_folders = os.path.exists(folder_1) and os.path.exists(folder_2)

    if use_csv_folders:
        df1 = load_dataset_from_folder(folder_1)
        df2 = load_dataset_from_folder(folder_2)

        df1["dataset_source"] = "with_inlet"
        df2["dataset_source"] = "no_inlet"

        # Make sample IDs unique so sample_0001 from both folders do not collide.
        df1["sample_id"] = "with_inlet_" + df1["sample_id"].astype(str)
        df2["sample_id"] = "no_inlet_" + df2["sample_id"].astype(str)

        df = pd.concat([df1, df2], ignore_index=True)
        print("Loaded CSV folders.")
    else:
        # Fallback demo mode if the folders are not found.
        print("CSV folders not found. Falling back to generated artificial data.")
        df = generate_artificial_dataset(CFG)

    print("Dataset shape:", df.shape)
    print(df.head())

    # Save loaded/combined dataset for inspection.
    df.to_csv(os.path.join(output_dir, "combined_cure_dataset.csv"), index=False)

    # ------------------------------------------------------------
    # Step 2: Split by sample, not by row
    # ------------------------------------------------------------
    train_ids, val_ids, test_ids = split_sample_ids(df)
    print(f"Train samples: {len(train_ids)} | Val samples: {len(val_ids)} | Test samples: {len(test_ids)}")

    train_ds = CureSequenceDataset(
        df,
        train_ids,
        CFG.input_features,
        CFG.target_col,
        CFG.reference_col,
        fit_scaler=True,
    )
    val_ds = CureSequenceDataset(
        df,
        val_ids,
        CFG.input_features,
        CFG.target_col,
        CFG.reference_col,
        scaler=train_ds.scaler,
    )
    test_ds = CureSequenceDataset(
        df,
        test_ids,
        CFG.input_features,
        CFG.target_col,
        CFG.reference_col,
        scaler=train_ds.scaler,
    )

    train_loader = DataLoader(train_ds, batch_size=CFG.batch_size, shuffle=True, collate_fn=cure_collate_fn)
    val_loader = DataLoader(val_ds, batch_size=CFG.batch_size, shuffle=False, collate_fn=cure_collate_fn)
    test_loader = DataLoader(test_ds, batch_size=CFG.batch_size, shuffle=False, collate_fn=cure_collate_fn)

    # ------------------------------------------------------------
    # Step 3: Train LSTM
    # ------------------------------------------------------------
    model = LSTMDoCModel(
        input_size=len(CFG.input_features),
        hidden_size=CFG.hidden_size,
        num_layers=CFG.num_layers,
        dropout=CFG.dropout,
    ).to(DEVICE)

    history = train_model(model, train_loader, val_loader, CFG)
    history.to_csv(os.path.join(output_dir, "training_history.csv"), index=False)
    plot_training_history(history, output_dir)

    # ------------------------------------------------------------
    # Step 4: Evaluate and predict test samples
    # ------------------------------------------------------------
    test_loss = evaluate(model, test_loader, CFG)
    print("Test losses:")
    for k, v in test_loss.items():
        print(f"  {k}: {v:.6f}")

    pred_df = predict_dataset(model, test_ds)
    pred_df.to_csv(os.path.join(output_dir, "test_predictions.csv"), index=False)

    # ------------------------------------------------------------
    # Step 5: Build abnormal cure report
    # ------------------------------------------------------------
    report_df = build_report(pred_df, CFG)
    report_df.to_csv(os.path.join(output_dir, "cure_classification_report.csv"), index=False)

    print("\nClassification report preview:")
    print(report_df.head(20))

    plot_report_summary(report_df, output_dir)

    # ------------------------------------------------------------
    # Step 6: Plot representative samples
    # ------------------------------------------------------------
    # Plot a few samples from different classes.
    chosen = []
    for label in report_df["classification"].unique():
        sid = report_df[report_df["classification"] == label]["sample_id"].iloc[0]
        chosen.append(sid)

    for sid in chosen[:6]:
        plot_sample(pred_df, report_df, sid, output_dir)

    # ------------------------------------------------------------
    # Step 7: Save model
    # ------------------------------------------------------------
    torch.save({
        "model_state_dict": model.state_dict(),
        "config": CFG.__dict__,
        "feature_cols": CFG.input_features,
        "scaler_mean": train_ds.scaler.mean_,
        "scaler_scale": train_ds.scaler.scale_,
    }, os.path.join(output_dir, "hybrid_lstm_doc_model.pt"))

    print(f"\nDone. Outputs saved to: {output_dir}/")


if __name__ == "__main__":
    main()
