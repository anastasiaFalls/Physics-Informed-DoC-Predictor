def plot_sample(pred_df, report_df, sample_id, output_dir="outputs"):
    os.makedirs(output_dir, exist_ok=True)
    g = pred_df[pred_df["sample_id"] == sample_id].sort_values("Time")
    r = report_df[report_df["sample_id"] == sample_id].iloc[0]

    t = g["Time"].to_numpy()
    temp = g["Temperature"].to_numpy()
    true_doc = g["True_DoC"].to_numpy()
    pred_doc = g["Pred_DoC"].to_numpy()
    iso_doc = g["Iso_DoC"].to_numpy()
    lower = g["Lower_95"].to_numpy()
    upper = g["Upper_95"].to_numpy()

    plt.figure(figsize=(10, 6))
    plt.plot(t, true_doc, label="True DoC")
    plt.plot(t, pred_doc, label="LSTM predicted DoC")
    plt.plot(t, iso_doc, label="Forward/isoconversion DoC")
    plt.fill_between(t, lower, upper, alpha=0.20, label="95% uncertainty band")

    # Mark thermal abnormal regions.
    hot = temp > CFG.safe_temp_c
    if np.any(hot):
        plt.scatter(t[hot], pred_doc[hot], s=12, label="Thermal flagged region")

    plt.xlabel("Time [min]")
    plt.ylabel("Degree of Cure")
    plt.ylim(-0.05, 1.08)
    plt.title(f"{sample_id}: {r['classification']} | {r['flags']}")
    plt.legend()
    plt.tight_layout()
    plt.savefig(os.path.join(output_dir, f"{sample_id}_doc_prediction.png"), dpi=200)
    plt.show()

    plt.figure(figsize=(10, 4))
    plt.plot(t, temp, label="Temperature")
    plt.axhline(CFG.safe_temp_c, linestyle="--", label="Safe temp threshold")
    plt.axhline(CFG.burn_temp_c, linestyle=":", label="Burn threshold")
    plt.xlabel("Time [min]")
    plt.ylabel("Temperature [°C]")
    plt.title(f"{sample_id}: Temperature Profile")
    plt.legend()
    plt.tight_layout()
    plt.savefig(os.path.join(output_dir, f"{sample_id}_temperature.png"), dpi=200)
    plt.show()


