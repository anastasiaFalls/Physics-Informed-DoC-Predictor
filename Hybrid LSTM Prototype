class CureSequenceDataset(Dataset):
    def __init__(self, df, sample_ids, feature_cols, target_col, reference_col, scaler=None, fit_scaler=False):
        self.df = df[df["sample_id"].isin(sample_ids)].copy()
        self.sample_ids = sorted(self.df["sample_id"].unique())
        self.feature_cols = list(feature_cols)
        self.target_col = target_col
        self.reference_col = reference_col

        if scaler is None:
            scaler = StandardScaler()
        self.scaler = scaler

        if fit_scaler:
            all_features = self.df[self.feature_cols].to_numpy(dtype=np.float32)
            self.scaler.fit(all_features)

    def __len__(self):
        return len(self.sample_ids)

    def __getitem__(self, idx):
        sid = self.sample_ids[idx]
        g = self.df[self.df["sample_id"] == sid].sort_values("Time").copy()

        # Force all model columns to be numeric. This prevents object-dtype arrays
        # from sneaking into PyTorch and causing dtype inference errors.
        cols_to_numeric = list(self.feature_cols) + [self.target_col, self.reference_col, "Time", "Temperature"]
        for col in cols_to_numeric:
            g[col] = pd.to_numeric(g[col], errors="coerce")

        # Drop any rows with missing model-critical values.
        g = g.dropna(subset=cols_to_numeric)

        x = g[self.feature_cols].to_numpy(dtype=np.float32)
        x = self.scaler.transform(x)
        x = np.asarray(x, dtype=np.float32)

        y = g[self.target_col].to_numpy(dtype=np.float32).reshape(-1, 1)
        iso = g[self.reference_col].to_numpy(dtype=np.float32).reshape(-1, 1)
        time = g["Time"].to_numpy(dtype=np.float32).reshape(-1, 1)
        temp = g["Temperature"].to_numpy(dtype=np.float32).reshape(-1, 1)

        return {
            "sample_id": sid,
            "x": torch.from_numpy(x),
            "y": torch.from_numpy(np.asarray(y, dtype=np.float32)),
            "iso": torch.from_numpy(np.asarray(iso, dtype=np.float32)),
            "time": torch.from_numpy(np.asarray(time, dtype=np.float32)),
            "temp": torch.from_numpy(np.asarray(temp, dtype=np.float32)),
        }


def split_sample_ids(df, train_frac=0.75, val_frac=0.10):
    ids = sorted(df["sample_id"].unique())
    random.shuffle(ids)

    n = len(ids)
    n_train = int(train_frac * n)
    n_val = int(val_frac * n)

    train_ids = ids[:n_train]
    val_ids = ids[n_train:n_train + n_val]
    test_ids = ids[n_train + n_val:]

    return train_ids, val_ids, test_ids


def cure_collate_fn(batch):
    """
    Custom collate function for variable-length cure sequences.

    Different CSVs can have different numbers of time points, e.g. [633, 3]
    and [721, 3]. PyTorch's default DataLoader cannot stack those directly.
    This pads each sequence to the longest sequence in the batch and returns
    a mask so padded regions can be ignored in the loss.
    """
    sample_ids = [item["sample_id"] for item in batch]
    lengths = torch.tensor([item["x"].shape[0] for item in batch], dtype=torch.long)

    x = pad_sequence([item["x"] for item in batch], batch_first=True, padding_value=0.0)
    y = pad_sequence([item["y"] for item in batch], batch_first=True, padding_value=0.0)
    iso = pad_sequence([item["iso"] for item in batch], batch_first=True, padding_value=0.0)
    time = pad_sequence([item["time"] for item in batch], batch_first=True, padding_value=0.0)
    temp = pad_sequence([item["temp"] for item in batch], batch_first=True, padding_value=0.0)

    max_len = x.shape[1]
    mask = torch.arange(max_len).unsqueeze(0) < lengths.unsqueeze(1)
    mask = mask.unsqueeze(-1).float()

    return {
        "sample_id": sample_ids,
        "x": x,
        "y": y,
        "iso": iso,
        "time": time,
        "temp": temp,
        "mask": mask,
        "lengths": lengths,
    }


