class LSTMDoCModel(nn.Module):
    """
    LSTM model that predicts:
        mean DoC prediction
        log variance for uncertainty

    Output shape:
        mean:    [batch, time, 1]
        log_var: [batch, time, 1]
    """
    def __init__(self, input_size, hidden_size=64, num_layers=2, dropout=0.1):
        super().__init__()
        self.lstm = nn.LSTM(
            input_size=input_size,
            hidden_size=hidden_size,
            num_layers=num_layers,
            batch_first=True,
            dropout=dropout if num_layers > 1 else 0.0,
        )
        self.head = nn.Sequential(
            nn.Linear(hidden_size, hidden_size),
            nn.ReLU(),
            nn.Linear(hidden_size, 2),
        )

    def forward(self, x):
        h, _ = self.lstm(x)
        out = self.head(h)

        raw_mean = out[..., 0:1]
        log_var = out[..., 1:2]

        # Keep prediction mostly physical, but bounds loss still helps training.
        mean = torch.sigmoid(raw_mean)
        log_var = torch.clamp(log_var, min=-8.0, max=4.0)

        return mean, log_var


# ============================================================
# 6. Physics-informed losses
# ============================================================

def masked_mean(values, mask):
    """Mean over only real, non-padded time points."""
    return torch.sum(values * mask) / torch.clamp(torch.sum(mask), min=1.0)


def gaussian_nll_loss(pred_mean, pred_log_var, target, mask=None):
    """Uncertainty-aware data loss."""
    inv_var = torch.exp(-pred_log_var)
    values = 0.5 * inv_var * (target - pred_mean) ** 2 + 0.5 * pred_log_var
    if mask is None:
        return torch.mean(values)
    return masked_mean(values, mask)


def monotonicity_loss(pred, mask=None):
    """Penalize DoC decreasing with time."""
    delta = pred[:, 1:, :] - pred[:, :-1, :]
    values = torch.relu(-delta)
    if mask is None:
        return torch.mean(values)
    pair_mask = mask[:, 1:, :] * mask[:, :-1, :]
    return masked_mean(values, pair_mask)


def bounds_loss(pred, mask=None):
    """Penalize predictions outside [0, 1]. Sigmoid already helps, but this is modular."""
    lower = torch.relu(-pred)
    upper = torch.relu(pred - 1.0)
    values = lower**2 + upper**2
    if mask is None:
        return torch.mean(values)
    return masked_mean(values, mask)


def isoconversion_loss(pred, iso, mask=None):
    """Compare predicted trajectory to forward-solver/isoconversion reference."""
    values = (pred - iso) ** 2
    if mask is None:
        return torch.mean(values)
    return masked_mean(values, mask)


def kinetics_rate_loss(pred, iso, time, mask=None):
    """
    Compare predicted cure rate to reference cure rate.

    This is a practical placeholder for physics loss:
        dα_pred/dt should approximately follow dα_iso/dt.

    Later you can replace dα_iso/dt with your actual kinetics equation.
    """
    dt = time[:, 1:, :] - time[:, :-1, :]
    dt = torch.clamp(dt, min=1e-6)

    pred_rate = (pred[:, 1:, :] - pred[:, :-1, :]) / dt
    iso_rate = (iso[:, 1:, :] - iso[:, :-1, :]) / dt

    values = (pred_rate - iso_rate) ** 2
    if mask is None:
        return torch.mean(values)
    pair_mask = mask[:, 1:, :] * mask[:, :-1, :]
    return masked_mean(values, pair_mask)


def total_loss_fn(pred, log_var, y, iso, time, cfg: Config, mask=None):
    data = gaussian_nll_loss(pred, log_var, y, mask=mask)
    iso_l = isoconversion_loss(pred, iso, mask=mask)
    mono = monotonicity_loss(pred, mask=mask)
    bnd = bounds_loss(pred, mask=mask)
    kin = kinetics_rate_loss(pred, iso, time, mask=mask)

    # Regularize uncertainty so it does not inflate like a cowardly little balloon.
    unc_values = torch.exp(log_var)
    unc_reg = masked_mean(unc_values, mask) if mask is not None else torch.mean(unc_values)

    total = (
        cfg.w_data * data
        + cfg.w_iso * iso_l
        + cfg.w_monotonic * mono
        + cfg.w_bounds * bnd
        + cfg.w_kinetics * kin
        + cfg.w_uncertainty * unc_reg
    )

    components = {
        "total": total.item(),
        "data": data.item(),
        "iso": iso_l.item(),
        "mono": mono.item(),
        "bounds": bnd.item(),
        "kinetics": kin.item(),
        "uncertainty": unc_reg.item(),
    }

    return total, components


# ============================================================
# 7. Training and evaluation
# ============================================================

def train_one_epoch(model, loader, optimizer, cfg):
    model.train()
    epoch_losses = []

    for batch in loader:
        x = batch["x"].to(DEVICE)
        y = batch["y"].to(DEVICE)
        iso = batch["iso"].to(DEVICE)
        time = batch["time"].to(DEVICE)

        optimizer.zero_grad()
        pred, log_var = model(x)
        mask = batch.get("mask")
        mask = mask.to(DEVICE) if mask is not None else None
        loss, comps = total_loss_fn(pred, log_var, y, iso, time, cfg, mask=mask)
        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        optimizer.step()

        epoch_losses.append(comps)

    return pd.DataFrame(epoch_losses).mean().to_dict()


def evaluate(model, loader, cfg):
    model.eval()
    losses = []

    with torch.no_grad():
        for batch in loader:
            x = batch["x"].to(DEVICE)
            y = batch["y"].to(DEVICE)
            iso = batch["iso"].to(DEVICE)
            time = batch["time"].to(DEVICE)

            pred, log_var = model(x)
            mask = batch.get("mask")
            mask = mask.to(DEVICE) if mask is not None else None
            _, comps = total_loss_fn(pred, log_var, y, iso, time, cfg, mask=mask)
            losses.append(comps)

    return pd.DataFrame(losses).mean().to_dict()


def train_model(model, train_loader, val_loader, cfg):
    optimizer = torch.optim.Adam(model.parameters(), lr=cfg.learning_rate)
    history = []

    for epoch in range(1, cfg.epochs + 1):
        train_loss = train_one_epoch(model, train_loader, optimizer, cfg)
        val_loss = evaluate(model, val_loader, cfg)

        row = {"epoch": epoch}
        row.update({f"train_{k}": v for k, v in train_loss.items()})
        row.update({f"val_{k}": v for k, v in val_loss.items()})
        history.append(row)

        if epoch == 1 or epoch % 10 == 0:
            print(
                f"Epoch {epoch:03d} | "
                f"train total: {train_loss['total']:.5f} | "
                f"val total: {val_loss['total']:.5f} | "
                f"val data: {val_loss['data']:.5f}"
            )

    return pd.DataFrame(history)


# ============================================================
# 8. Prediction utilities
# ============================================================

def predict_dataset(model, dataset):
    model.eval()
    rows = []

    with torch.no_grad():
        for i in range(len(dataset)):
            item = dataset[i]
            sid = item["sample_id"]
            x = item["x"].unsqueeze(0).to(DEVICE)

            pred, log_var = model(x)
            pred = pred.squeeze(0).cpu().numpy().reshape(-1)
            std = np.sqrt(np.exp(log_var.squeeze(0).cpu().numpy().reshape(-1)))

            # Recover original unscaled values from stored tensors/df fields.
            y = item["y"].numpy().reshape(-1)
            iso = item["iso"].numpy().reshape(-1)
            time = item["time"].numpy().reshape(-1)
            temp = item["temp"].numpy().reshape(-1)

            for j in range(len(time)):
                rows.append({
                    "sample_id": sid,
                    "Time": time[j],
                    "Temperature": temp[j],
                    "True_DoC": y[j],
                    "Pred_DoC": pred[j],
                    "Iso_DoC": iso[j],
                    "Pred_Std": std[j],
                    "Lower_95": max(0.0, pred[j] - 1.96 * std[j]),
                    "Upper_95": min(1.0, pred[j] + 1.96 * std[j]),
                })

    return pd.DataFrame(rows)


# ============================================================
# 9. S-curve validation and abnormal cure classification
# ============================================================

def smooth_curve(y, window=21, poly=3):
    if len(y) < window:
        return y
    if window % 2 == 0:
        window += 1
    return savgol_filter(y, window_length=window, polyorder=poly)


def classify_sample(g, cfg: Config):
    """
    Classify one sample using predicted DoC, reference DoC, and temperature.

    This is intentionally rule-based for the MVP.
    Later, this can become a learned anomaly detector.
    """
    g = g.sort_values("Time")
    t = g["Time"].to_numpy()
    pred = g["Pred_DoC"].to_numpy()
    iso = g["Iso_DoC"].to_numpy()
    temp = g["Temperature"].to_numpy()

    pred_s = smooth_curve(pred)
    dt = np.gradient(t)
    rate = np.gradient(pred_s, t)

    final_doc = pred_s[-1]
    max_temp = np.max(temp)
    rmse_iso = np.sqrt(np.mean((pred_s - iso) ** 2))
    min_delta = np.min(np.diff(pred_s))
    max_rate = np.max(rate)

    flags = []

    if rmse_iso > cfg.s_curve_rmse_threshold or min_delta < -0.03:
        flags.append("invalid S-curve")

    if final_doc < cfg.min_final_doc:
        flags.append("under-cure")

    if final_doc > cfg.max_final_doc:
        flags.append("over-cure")

    if max_temp > cfg.burn_temp_c:
        flags.append("possible burn / thermal runaway")
    elif max_temp > cfg.safe_temp_c:
        flags.append("thermal limit exceeded")

    # Early plateau: curve flattens before reaching acceptable cure.
    mid = len(pred_s) // 2
    late_rate = np.mean(np.abs(rate[mid:]))
    if final_doc < cfg.early_plateau_doc and late_rate < cfg.min_doc_rate_mid_cure:
        flags.append("plateau too early")

    # Slow cure: low final DoC but not necessarily plateaued.
    if final_doc < cfg.min_final_doc and np.mean(rate[mid:]) < cfg.min_doc_rate_mid_cure * 3:
        flags.append("cure progressing too slowly")

    if max_rate > cfg.max_doc_rate_per_min:
        flags.append("unusually fast cure rate")

    if not flags:
        label = "normal cure"
    elif any("burn" in f for f in flags) or any("thermal" in f for f in flags):
        label = "possible burn/thermal issue"
    elif "invalid S-curve" in flags:
        label = "invalid S-curve"
    elif "under-cure" in flags:
        label = "under-cure"
    elif "over-cure" in flags:
        label = "over-cure"
    else:
        label = flags[0]

    return {
        "sample_id": g["sample_id"].iloc[0],
        "classification": label,
        "flags": "; ".join(flags) if flags else "none",
        "final_pred_doc": final_doc,
        "max_temperature_C": max_temp,
        "rmse_vs_iso": rmse_iso,
        "min_doc_step": min_delta,
        "max_doc_rate_per_min": max_rate,
    }


def build_report(pred_df, cfg: Config):
    reports = []
    for sid, g in pred_df.groupby("sample_id"):
        reports.append(classify_sample(g, cfg))
    return pd.DataFrame(reports).sort_values(["classification", "sample_id"])


