def load_dataset_from_folder(folder):
    """
    Load real or artificial CSV files from a folder.

    Expected columns:
        Time, Temperature, Sensor_Value, Degree_of_Cure, Cure_Index

    Optional columns:
        Iso_DoC, sample_id

    If Iso_DoC does not exist, this function creates a placeholder reference using the forward solver.
    """
    csv_files = sorted(glob.glob(os.path.join(folder, "*.csv")))
    if not csv_files:
        raise FileNotFoundError(f"No CSV files found in folder: {folder}")

    df_list = []
    for file in csv_files:
        temp_df = pd.read_csv(file)
        if "sample_id" not in temp_df.columns:
            temp_df["sample_id"] = os.path.splitext(os.path.basename(file))[0]
        df_list.append(temp_df)

    df = pd.concat(df_list, ignore_index=True)

    required = {"sample_id", "Time", "Temperature", "Sensor_Value", "Degree_of_Cure"}
    missing = required - set(df.columns)
    if missing:
        raise ValueError(f"Missing required columns: {missing}")

    if "Cure_Index" not in df.columns:
        df["Cure_Index"] = df.groupby("sample_id")["Degree_of_Cure"].transform(
            lambda x: np.gradient(x.to_numpy())
        )

    if "Iso_DoC" not in df.columns:
        iso_values = []
        for _, g in df.groupby("sample_id"):
            iso = forward_solver_isoconversion(
                g["Time"].to_numpy(),
                g["Temperature"].to_numpy(),
            )
            iso_values.extend(iso)
        df["Iso_DoC"] = iso_values

    return df


