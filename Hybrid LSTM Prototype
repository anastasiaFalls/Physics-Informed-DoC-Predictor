from scipy.interpolate import interp1d
from scipy.integrate import cumulative_trapezoid


def baseline_correct_dsc(df, ref_start_1, ref_end_1, ref_start_2, ref_end_2):
    """
    Baseline-correct DSC heat flow using two non-reaction regions.

    This mirrors the old MATLAB/Python preprocessing workflow:
        1. Select early and late temperature/heat-flow regions.
        2. Build a baseline heat-flow function HF_baseline(T).
        3. Subtract baseline from measured heat flow.

    Inputs use Python slicing conventions:
        ref_start_1:ref_end_1 and ref_start_2:ref_end_2

    Required columns:
        Temperature, Heat Flow
    """
    refT = pd.concat([
        df["Temperature"].iloc[ref_start_1:ref_end_1],
        df["Temperature"].iloc[ref_start_2:ref_end_2],
    ]).reset_index(drop=True)

    refHF = pd.concat([
        df["Heat Flow"].iloc[ref_start_1:ref_end_1],
        df["Heat Flow"].iloc[ref_start_2:ref_end_2],
    ]).reset_index(drop=True)

    df_ref = pd.DataFrame({"T": refT.values, "HF": refHF.values})
    df_ref = df_ref.groupby("T", as_index=False)["HF"].mean()

    baseline_fn = interp1d(
        df_ref["T"],
        df_ref["HF"],
        kind="linear",
        fill_value="extrapolate",
    )

    df = df.copy()
    df["HF_baseline"] = baseline_fn(df["Temperature"].values)
    df["Heat Flow_corrected"] = df["Heat Flow"] - df["HF_baseline"]
    return df


def compute_alpha_from_dsc(df, time_col="Time", hf_col="Heat Flow_corrected", alpha_col="alpha"):
    """
    Compute degree of cure from baseline-corrected DSC heat flow.

    α(t) = cumulative heat released / total heat released

    Required columns:
        Time, Heat Flow_corrected
    """
    df = df.copy()
    t = df[time_col].astype(float).values
    hf = df[hf_col].astype(float).values

    # If time is not strictly increasing, fall back to index spacing.
    if np.any(np.diff(t) <= 0):
        t = np.arange(len(hf), dtype=float)

    cumH = cumulative_trapezoid(hf, t, initial=0.0)
    totalH = cumH[-1]

    if totalH == 0 or np.isnan(totalH):
        alpha = np.zeros_like(cumH)
    else:
        alpha = cumH / totalH

    alpha = np.clip(alpha, 0.0, 1.0)
    alpha = np.maximum.accumulate(alpha)

    df[alpha_col] = alpha
    df["cumH"] = cumH
    df["totalH"] = totalH
    return df


def load_and_process_dsc_csv(path, resin_weight_g, baseline_slices):
    """
    Load one DSC CSV and compute baseline-corrected heat flow and α(t).

    Expected raw columns:
        Time, Temperature, Heat Flow, Heat Capacity, Purge Flow

    Parameters:
        path: path to CSV
        resin_weight_g: resin mass used to normalize heat flow
        baseline_slices: tuple like (start1, end1, start2, end2)
    """
    df = pd.read_csv(
        path,
        header=None,
        names=["Time", "Temperature", "Heat Flow", "Heat Capacity", "Purge Flow"],
    )

    df["Heat Flow"] = df["Heat Flow"] * 1e-3 / resin_weight_g
    df = baseline_correct_dsc(df, *baseline_slices)
    df = compute_alpha_from_dsc(df)
    return df


def fit_isoconversion_parameters(processed_dsc_runs, alpha_fit_grid=None):
    """
    Fit isoconversion parameters Ea(α) and C(α) from multiple DSC runs.

    For each fixed α, interpolate across each DSC heating-rate run to get:
        Tα and dα/dt

    Then fit:
        ln(dα/dt) = C(α) - Ea(α)/(R*T)

    Returns a DataFrame with columns:
        alpha, Ea, C

    Important:
        Temperature is converted from Celsius to Kelvin inside this function.
        The time unit of dα/dt follows the Time column in your DSC files.
    """
    if alpha_fit_grid is None:
        alpha_fit_grid = np.arange(0.1, 1.0, 0.1)

    R = 8.314
    rows = []

    prepared = []
    for df in processed_dsc_runs:
        d = df.copy().sort_values("Time")
        time = d["Time"].to_numpy(dtype=float)
        temp_c = d["Temperature"].to_numpy(dtype=float)
        alpha = d["alpha"].to_numpy(dtype=float)

        dalpha_dt = np.gradient(alpha, time)
        dalpha_dt = np.clip(dalpha_dt, 1e-12, None)

        # Remove repeated alpha values so interpolation behaves.
        alpha_unique, unique_idx = np.unique(alpha, return_index=True)
        temp_unique = temp_c[unique_idx]
        rate_unique = dalpha_dt[unique_idx]

        prepared.append((alpha_unique, temp_unique, rate_unique))

    for a in alpha_fit_grid:
        T_list = []
        rate_list = []

        for alpha_unique, temp_unique, rate_unique in prepared:
            if a < alpha_unique.min() or a > alpha_unique.max():
                continue

            T_a_c = np.interp(a, alpha_unique, temp_unique)
            rate_a = np.interp(a, alpha_unique, rate_unique)

            if np.isfinite(T_a_c) and np.isfinite(rate_a) and rate_a > 0:
                T_list.append(T_a_c + 273.15)
                rate_list.append(rate_a)

        if len(T_list) < 2:
            continue

        T_arr = np.asarray(T_list, dtype=float)
        rate_arr = np.asarray(rate_list, dtype=float)

        x = 1.0 / T_arr
        y = np.log(rate_arr)
        P = np.polyfit(x, y, 1)

        Ea = -R * P[0]
        C = P[1]

        rows.append({"alpha": a, "Ea": Ea, "C": C})

    return pd.DataFrame(rows)


